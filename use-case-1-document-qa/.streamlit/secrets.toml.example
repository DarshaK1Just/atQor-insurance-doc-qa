# Paste this into your Streamlit Cloud app's Secrets panel:
#   App dashboard → Settings → Secrets → paste and Save
#
# Every key here becomes an environment variable that pydantic Settings reads.
# Do NOT commit the real secrets.toml file — only this .example file is tracked.

# ── LLM provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER = "gemini"                   # "gemini" or "azure"
GEMINI_API_KEY = "your-gemini-api-key"
GEMINI_CHAT_MODEL = "gemini-2.5-flash"

# ── Azure OpenAI (embeddings — always required even when using Gemini) ────────
AZURE_OPENAI_ENDPOINT = "https://your-resource.openai.azure.com/"
AZURE_OPENAI_API_KEY = "your-azure-openai-key"
AZURE_OPENAI_API_VERSION = "2024-10-21"
AZURE_OPENAI_EMBED_DEPLOYMENT = "text-embedding-3-small"
STRUCTURED_OUTPUTS = "off"               # gemini doesn't support structured outputs

# ── Azure AI Document Intelligence ───────────────────────────────────────────
DOCINTEL_ENDPOINT = "https://your-docintel.cognitiveservices.azure.com/"
DOCINTEL_KEY = "your-doc-intel-key"

# ── Azure AI Search ───────────────────────────────────────────────────────────
SEARCH_ENDPOINT = "https://your-search.search.windows.net"
SEARCH_KEY = "your-search-admin-key"
SEARCH_INDEX_NAME = "insurance-chunks"

# ── App behaviour ─────────────────────────────────────────────────────────────
API_BASE_URL = "http://127.0.0.1:8001"   # internal — FastAPI runs in the same process
VERIFY_SSL = "true"                       # Streamlit Cloud has a valid cert chain
