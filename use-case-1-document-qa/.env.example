# ── Azure OpenAI (Free Account $200 credit; no free tier exists for AOAI) ─────
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com/
AZURE_OPENAI_API_KEY=                      # leave empty to use DefaultAzureCredential (az login / managed identity)
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini   # swap to gpt-4o, or a free serverless model name (e.g. Kimi-k2.6)
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
EMBED_DIMENSIONS=1536
# Structured Outputs: "auto" probes once; "on" forces it (gpt-4o); "off" skips it.
# Set "off" for Kimi/serverless models to save a wasted round-trip on every turn.
STRUCTURED_OUTPUTS=auto

# ── Azure AI Document Intelligence (F0 free tier: 500 pages/month) ────────────
DOCINTEL_ENDPOINT=https://<your-docintel>.cognitiveservices.azure.com/
DOCINTEL_KEY=                              # leave empty to use DefaultAzureCredential
# F0 silently analyzes ONLY the first 2 pages per request. The ingestion
# pipeline splits PDFs into windows of this many pages and merges results
# with correct page offsets. Set 0 to disable on a paid S0 resource.
DOCINTEL_PAGE_WINDOW=2

# ── Azure AI Search (Free F1 tier: hybrid search yes, semantic ranker no) ─────
SEARCH_ENDPOINT=https://<your-search>.search.windows.net
SEARCH_KEY=                                # admin key; leave empty to use DefaultAzureCredential
SEARCH_INDEX_NAME=insurance-chunks

# ── Azure Blob Storage (optional — falls back to local ./data if unset) ───────
BLOB_CONNECTION_STRING=
BLOB_CONTAINER_ORIGINALS=originals
BLOB_CONTAINER_EXTRACTS=extracts

# ── TLS verification ──────────────────────────────────────────────────────────
# Keep true in production. Set false ONLY for a local demo behind a corporate
# TLS-intercepting proxy whose root CA isn't in Python's trust store — symptom:
# every Azure call fails with CERTIFICATE_VERIFY_FAILED. Proper fix: add the
# corporate root CA (see docs/SETUP.md → Troubleshooting).
VERIFY_SSL=true

# ── App behaviour ──────────────────────────────────────────────────────────────
DATA_DIR=./data
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=80
TOP_K=5
COMPARE_K_PER_DOC=4
COMPARE_MAX_DOCS=8
RRF_FLOOR=0.01
API_BASE_URL=http://localhost:8000

# ── Agentic RAG (Corrective-RAG: self-grade retrieval, re-query if weak) ──────
AGENTIC_RAG=true            # set false for the leanest/fastest path (skips the grade step)
AGENTIC_MAX_RETRIES=1       # corrective re-query attempts on weak retrieval
AGENTIC_RECALL_K=8          # widened top-k used on a corrective retry
WARMUP_ON_STARTUP=false     # true = warm the serverless model on boot (hides first-query cold-start)
